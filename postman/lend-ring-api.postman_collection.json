{
  "info": {
    "name": "Lend-Ring API",
    "description": "All Lend-Ring endpoints. Log in with any account first - the token is saved automatically and used by every other request. Set itemId / bookingId variables as needed.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "itemId", "value": "" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"new.user@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"renter\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"arun.renter@demo.dev\",\n  \"password\": \"demo1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Current session",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "My profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] }
          }
        },
        {
          "name": "Update profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"phone\": \"9876543210\",\n  \"city\": \"Chennai\",\n  \"pincode\": \"600042\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] }
          }
        },
        {
          "name": "Change password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"demo1234\",\n  \"newPassword\": \"newpassword123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/me/password", "host": ["{{baseUrl}}"], "path": ["users", "me", "password"] }
          }
        }
      ]
    },
    {
      "name": "Items (lender)",
      "item": [
        {
          "name": "Create listing",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('itemId', pm.response.json().item._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Canon EOS 1500D DSLR\",\n  \"description\": \"24MP DSLR with 18-55mm kit lens\",\n  \"category\": \"electronics\",\n  \"ratePerDay\": 45000,\n  \"depositAmount\": 200000\n}"
            },
            "url": { "raw": "{{baseUrl}}/items", "host": ["{{baseUrl}}"], "path": ["items"] }
          }
        },
        {
          "name": "My listings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/items/mine", "host": ["{{baseUrl}}"], "path": ["items", "mine"] }
          }
        },
        {
          "name": "Update listing",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ratePerDay\": 50000,\n  \"status\": \"active\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["items", "{{itemId}}"] }
          }
        },
        {
          "name": "Delete listing",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["items", "{{itemId}}"] }
          }
        },
        {
          "name": "Upload photos",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "photos", "type": "file", "src": [] },
                { "key": "photos", "type": "file", "src": [] }
              ]
            },
            "url": { "raw": "{{baseUrl}}/items/{{itemId}}/photos", "host": ["{{baseUrl}}"], "path": ["items", "{{itemId}}", "photos"] }
          }
        },
        {
          "name": "Remove a photo",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"photoUrl\": \"https://res.cloudinary.com/...\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/items/{{itemId}}/photos", "host": ["{{baseUrl}}"], "path": ["items", "{{itemId}}", "photos"] }
          }
        }
      ]
    },
    {
      "name": "Browse",
      "item": [
        {
          "name": "Browse items",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/browse?search=&category=&city=&minRate=&maxRate=&page=1&limit=12",
              "host": ["{{baseUrl}}"],
              "path": ["browse"],
              "query": [
                { "key": "search", "value": "" },
                { "key": "category", "value": "" },
                { "key": "city", "value": "" },
                { "key": "minRate", "value": "" },
                { "key": "maxRate", "value": "" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "12" }
              ]
            }
          }
        },
        {
          "name": "Item detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/browse/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["browse", "{{itemId}}"] }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Request booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('bookingId', pm.response.json().booking._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemId\": \"{{itemId}}\",\n  \"startDate\": \"2026-08-10\",\n  \"endDate\": \"2026-08-12\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "My bookings (renter)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/mine", "host": ["{{baseUrl}}"], "path": ["bookings", "mine"] }
          }
        },
        {
          "name": "Bookings received (lender)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/received", "host": ["{{baseUrl}}"], "path": ["bookings", "received"] }
          }
        },
        {
          "name": "Approve booking (lender)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}/approve", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}", "approve"] }
          }
        },
        {
          "name": "Decline booking (lender)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}/decline", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}", "decline"] }
          }
        },
        {
          "name": "Cancel booking (renter)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}/cancel", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}", "cancel"] }
          }
        }
      ]
    }
  ]
}
