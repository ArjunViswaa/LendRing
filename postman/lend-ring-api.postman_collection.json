{
  "info": {
    "name": "Lend-Ring API",
    "description": "Booking lifecycle tests (Day 15). Run top to bottom with the Collection Runner. Uses fixed Aug 2026 dates - if approved bookings already exist on the tent from a previous run, run `npm run seed:demo` first to reset demo items.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "arunToken", "value": "" },
    { "key": "ashaToken", "value": "" },
    { "key": "raviToken", "value": "" },
    { "key": "priyaToken", "value": "" },
    { "key": "tentId", "value": "" },
    { "key": "arunBookingId", "value": "" },
    { "key": "ashaBooking1012", "value": "" },
    { "key": "ashaBooking1315", "value": "" }
  ],
  "item": [
    {
      "name": "0 Setup",
      "item": [
        {
          "name": "Health check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('server is up', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "Login arun (renter)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('logged in', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('arunToken', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"arun.renter@demo.dev\",\"password\":\"demo1234\"}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login asha (renter)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('logged in', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('ashaToken', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"asha@test.dev\",\"password\":\"AshaRent@123\"}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login ravi (lender, owns tent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('logged in', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('raviToken', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"ravi.lender@demo.dev\",\"password\":\"demo1234\"}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login priya (lender, does NOT own tent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('logged in', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('priyaToken', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"priya.lender@demo.dev\",\"password\":\"demo1234\"}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Find the tent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const items = pm.response.json().items;",
                  "pm.test('tent found', () => pm.expect(items.length).to.be.above(0));",
                  "pm.collectionVariables.set('tentId', items[0]._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{arunToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/browse?search=tent",
              "host": ["{{baseUrl}}"],
              "path": ["browse"],
              "query": [{ "key": "search", "value": "tent" }]
            }
          }
        }
      ]
    },
    {
      "name": "1 Conflict matrix",
      "item": [
        {
          "name": "Arun requests Aug 10-12",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('created', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json().booking;",
                  "pm.collectionVariables.set('arunBookingId', b._id);",
                  "pm.test('rent frozen: 3 days x 30000 = 90000', () => pm.expect(b.rentAmount).to.eql(90000));",
                  "pm.test('platform fee 10% = 9000', () => pm.expect(b.platformFee).to.eql(9000));",
                  "pm.test('total = rent + deposit = 240000', () => pm.expect(b.totalAmount).to.eql(240000));",
                  "pm.test('status is requested', () => pm.expect(b.status).to.eql('requested'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{arunToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"itemId\":\"{{tentId}}\",\"startDate\":\"2026-08-10\",\"endDate\":\"2026-08-12\"}" },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Asha requests SAME dates - allowed while only requested",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('also created - requested does not block', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('ashaBooking1012', pm.response.json().booking._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ashaToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"itemId\":\"{{tentId}}\",\"startDate\":\"2026-08-10\",\"endDate\":\"2026-08-12\"}" },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Ravi approves arun - dates now locked",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('approved', () => pm.response.to.have.status(200));",
                  "pm.test('status approved', () => pm.expect(pm.response.json().booking.status).to.eql('approved'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{raviToken}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/{{arunBookingId}}/approve", "host": ["{{baseUrl}}"], "path": ["bookings", "{{arunBookingId}}", "approve"] }
          }
        },
        {
          "name": "Ravi approves asha same dates - must fail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('409 - dates taken in the meantime', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{raviToken}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/{{ashaBooking1012}}/approve", "host": ["{{baseUrl}}"], "path": ["bookings", "{{ashaBooking1012}}", "approve"] }
          }
        },
        {
          "name": "New overlapping request now fails at request time",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('409 - overlaps approved range', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ashaToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"itemId\":\"{{tentId}}\",\"startDate\":\"2026-08-11\",\"endDate\":\"2026-08-13\"}" },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Adjacent dates Aug 13-15 - clear",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('created - 13th is free', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('ashaBooking1315', pm.response.json().booking._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ashaToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"itemId\":\"{{tentId}}\",\"startDate\":\"2026-08-13\",\"endDate\":\"2026-08-15\"}" },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Ravi approves the adjacent booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('approved', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{raviToken}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/{{ashaBooking1315}}/approve", "host": ["{{baseUrl}}"], "path": ["bookings", "{{ashaBooking1315}}", "approve"] }
          }
        },
        {
          "name": "Ravi declines asha's leftover request (cleanup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('declined', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{raviToken}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/{{ashaBooking1012}}/decline", "host": ["{{baseUrl}}"], "path": ["bookings", "{{ashaBooking1012}}", "decline"] }
          }
        }
      ]
    },
    {
      "name": "2 Guardrails",
      "item": [
        {
          "name": "Past start date refused",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('400 - cannot start in the past', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{arunToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"itemId\":\"{{tentId}}\",\"startDate\":\"2025-01-01\",\"endDate\":\"2025-01-03\"}" },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Return before pickup refused",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('400 - end before start', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{arunToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"itemId\":\"{{tentId}}\",\"startDate\":\"2026-09-10\",\"endDate\":\"2026-09-08\"}" },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Renter role blocked from approving",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('403 - wrong role', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{ashaToken}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/{{arunBookingId}}/approve", "host": ["{{baseUrl}}"], "path": ["bookings", "{{arunBookingId}}", "approve"] }
          }
        },
        {
          "name": "Other lender blocked from approving (ownership)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('403 - not their booking', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{priyaToken}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/{{arunBookingId}}/approve", "host": ["{{baseUrl}}"], "path": ["bookings", "{{arunBookingId}}", "approve"] }
          }
        },
        {
          "name": "No token refused",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('401 - login required', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/bookings/mine", "host": ["{{baseUrl}}"], "path": ["bookings", "mine"] }
          }
        }
      ]
    },
    {
      "name": "3 Lists",
      "item": [
        {
          "name": "Arun's bookings (item populated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "const bookings = pm.response.json().bookings;",
                  "pm.test('has bookings', () => pm.expect(bookings.length).to.be.above(0));",
                  "pm.test('item title populated', () => pm.expect(bookings[0].itemId.title).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{arunToken}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/mine", "host": ["{{baseUrl}}"], "path": ["bookings", "mine"] }
          }
        },
        {
          "name": "Ravi's received bookings (renter populated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "const bookings = pm.response.json().bookings;",
                  "pm.test('has bookings', () => pm.expect(bookings.length).to.be.above(0));",
                  "pm.test('renter name + trustScore visible', () => {",
                  "  pm.expect(bookings[0].renterId.name).to.be.a('string');",
                  "  pm.expect(bookings[0].renterId.trustScore).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{raviToken}}" }],
            "url": { "raw": "{{baseUrl}}/bookings/received", "host": ["{{baseUrl}}"], "path": ["bookings", "received"] }
          }
        }
      ]
    }
  ]
}
